{
  "$schema": "https://json.schemastore.org/package",
  "name": "homebridge-cli",
  "description": "Configure and manage Homebridge from the terminal",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": "./dist/main.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.13",
    "npm": ">=11.6"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/liam-hales/homebridge-cli.git"
  },
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "dev": "tsx src/main.tsx",
    "build": "tsc --project tsconfig.build.json",
    "lint": "eslint",
    "deps": "ncu --packageManager yarn",
    "cleanup": "rm -rf dist/ *.tsbuildinfo"
  },
  "dependencies": {
    "@alcalzone/ink-table": "^1.1.1",
    "@network-utils/tcp-ping": "^1.2.3",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "dayjs": "^1.11.20",
    "dedent": "^1.7.2",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "keytar": "^7.9.0",
    "nanoid": "^5.1.9",
    "react": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "eslint": "^10.2.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jiti": "^2.6.1",
    "npm-check-updates": "^21.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
